# ── Text validation (Ollama — always active) ──────────────────
# Pick ONE model and uncomment it. Run "ollama pull <model>" first if not installed.
#
# OLLAMA_MODEL=qwen2.5:3b     # ~2 GB  — fast, low RAM
# OLLAMA_MODEL=qwen2.5:7b     # ~4.7 GB — balanced (run: ollama pull qwen2.5:7b)
OLLAMA_MODEL=qwen2.5:7b      # ~9 GB  — best quality (installed ✓)

# ── Image detector switch ──────────────────────────────────────
# Set to "yolo" to use the local fine-tuned model (best.pt)
# Set to "nemotron" to use NVIDIA Nemotron cloud vision model
DETECTOR=nemotron

# ── YOLO settings (used when DETECTOR=yolo) ───────────────────
YOLO_MODEL_PATH=best.pt
YOLO_CONFIDENCE=0.20

# ── NVIDIA Nemotron settings (used when DETECTOR=nemotron) ────
NVIDIA_API_KEY=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
